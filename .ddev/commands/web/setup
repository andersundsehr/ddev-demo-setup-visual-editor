#!/bin/bash
set -euo pipefail

cd /var/www/html

rsync -a seed/demo.sqlite var/sqlite/demo.sqlite
rsync -a --delete seed/fileadmin public/

composer install
vendor/bin/typo3 extension:setup -n
vendor/bin/typo3 referenceindex:update
vendor/bin/typo3 cache:flush

printf '\n\033[1;36m========================================\033[0m\n'
printf '\033[1;32m✅ Setup done\033[0m\n'
printf '\033[1;36m========================================\033[0m\n\n'
