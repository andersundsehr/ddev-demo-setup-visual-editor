#!/bin/bash
set -euo pipefail

APP_ROOT="${DDEV_APPROOT:-$(pwd)}"

cd "${APP_ROOT}"

mkdir -p public/fileadmin

ddev composer install
ddev import-db --file="${APP_ROOT}/seed/demo.mysql.sql.gz"
rsync -a --delete "${APP_ROOT}/seed/fileadmin/" "${APP_ROOT}/public/fileadmin/"

ddev exec vendor/bin/typo3 extension:setup -n
ddev exec vendor/bin/typo3 referenceindex:update
ddev exec vendor/bin/typo3 cache:flush
ddev exec vendor/bin/typo3 language:update

printf '\n\033[1;36m========================================\033[0m\n'
printf '\033[1;32m✅ Setup done\033[0m\n'
printf '\033[1;36m========================================\033[0m\n\n'
